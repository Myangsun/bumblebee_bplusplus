@article{venverloo_towards_2024,
	title = {Towards real-time monitoring of insect species populations},
	volume = {14},
	copyright = {2024 The Author(s)},
	issn = {2045-2322},
	url = {https://www.nature.com/articles/s41598-024-68502-8},
	doi = {10.1038/s41598-024-68502-8},
	abstract = {Insect biodiversity and abundance are in global decline, potentially leading to a crisis with profound ecological and economic consequences. Methods and technologies to monitor insect species to aid in preservation efforts are rapidly being developed yet their adoption has been slow and focused on specific use cases. We propose a computer vision model that works towards multi-objective insect species identification in real-time and on a large scale. We leverage an image data source with 16 million instances and a recent improvement in the YOLO computer vision architecture to present a quick and open-access method to develop visual AI models to monitor insect species across climatic regions.},
	language = {en},
	number = {1},
	urldate = {2025-12-02},
	journal = {Scientific Reports},
	publisher = {Nature Publishing Group},
	author = {Venverloo, Titus and Duarte, Fábio},
	month = aug,
	year = {2024},
	keywords = {Classification and taxonomy, Climate-change ecology},
	pages = {18727},
	file = {Full Text PDF:/Users/mingyang/Zotero/storage/D8AU4PJV/Venverloo and Duarte - 2024 - Towards real-time monitoring of insect species populations.pdf:application/pdf},
}

