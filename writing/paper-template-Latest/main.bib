	keywords = {Computer Science - Machine Learning, Computer Science - Computer Vision and Pattern Recognition, Computer Science - Computation and Language},
	file = {Preprint PDF:/Users/mingyang/Zotero/storage/H2SQ6HLG/Stevens et al. - 2024 - BioCLIP A Vision Foundation Model for the Tree of Life.pdf:application/pdf;Snapshot:/Users/mingyang/Zotero/storage/ZXNCYDHZ/2311.html:text/html},
