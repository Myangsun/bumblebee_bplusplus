{
  "permissions": {
    "allow": [
      "Bash(file GBIF_MA_BUMBLEBEES/prepared_split/train/Bombus_ashtoni/*.jpg)",
      "Bash(file GBIF_MA_BUMBLEBEES/prepared_split/train/Bombus_ashtoni/*.png)",
      "WebFetch(domain:www.bumblebeewatch.org)",
      "WebFetch(domain:val.vtecostudies.org)",
      "WebFetch(domain:www.discoverlife.org)",
      "Bash(gh pr *)",
      "Bash(awk -F'[_@]' '{print $1\"_\"$2\"_\"$3}')"
    ],
    "additionalDirectories": [
      "/tmp"
    ],
      "hooks": {
    "PostToolUse": [{
      "matcher": "Edit|Write",
      "hooks": [{
        "type": "command",
        "command": "f=$(jq -r '.tool_input.file_path'); if [[ \"$f\" == *.py ]]; then ruff check \"$f\"; fi"
      }]
    }]
  }

  }
}
